# Copy to `.env` for local development (see README).
# SEC-001: values match docker-compose dev service only — never use in production.

PORT=3000
NODE_ENV=development

DB_HOST=127.0.0.1
# Matches docker-compose host port mapping (container listens on 5432 internally)
DB_PORT=5433
DB_USER=app
DB_PASSWORD=devpassword
# Primary app database (matches POSTGRES_DB in compose)
DB_NAME=app

# Optional: integration tests default to `app_test` via Jest setup if unset
# DB_NAME_INTEGRATION=app_test
