# Copy to .env for local use. Values are for trusted workstations only (SEC-001).
# Never use these defaults in production or shared environments.

POSTGRES_USER=app
POSTGRES_PASSWORD=app_local_dev_only
POSTGRES_DB=app
POSTGRES_PORT=5432

# Nest/TypeORM (convention — adjust when app scaffold exists)
DATABASE_URL=postgresql://app:app_local_dev_only@127.0.0.1:5432/app
