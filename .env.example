# Copy to .env for local development (never commit real secrets).
NODE_ENV=development
PORT=3000

# TableSpoonDB connection string (PostgreSQL wire protocol).
# Matches docker-compose defaults when using the bundled development database service.
DATABASE_URL=postgresql://app:app@127.0.0.1:5432/app

# Integration tests target an isolated database (created by compose init scripts).
TEST_DATABASE_URL=postgresql://app:app@127.0.0.1:5432/app_test
