# Copy to `.env` for local development (see README).
# SEC-001: values match Compose dev defaults only — never use in production.

PORT=3000
NODE_ENV=development

DB_HOST=127.0.0.1
# Matches Compose host port mapping (container listens on 5432 internally)
DB_PORT=5433
DB_USER=app
DB_PASSWORD=devpassword
# Primary application database (same as POSTGRES_DB in compose.yaml)
DB_NAME=app

# Optional: integration tests target this database (default `app_test`)
# DB_NAME_INTEGRATION=app_test
