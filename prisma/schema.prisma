generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Used by integration tests (TEST-002) to verify real DB writes; keep in sync with migrations.
model IntegrationProbe {
  id     Int    @id @default(autoincrement())
  marker String @unique

  @@map("integration_probe")
}
